{
  "name": "@weikinhuang/dotfiles",
  "version": "1.0.0",
  "private": true,
  "description": "My `$SHELL`, mostly bash, works everywhere, `*nix`, `osx`, `wsl`.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "eslint": "eslint .",
    "prepare": "husky || true",
    "oxfmt": "oxfmt",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "markdownlint": "markdownlint-cli2 --fix '**/*.{md,mdc}' '.*/**/*.{md,mdc}'",
    "markdownlint:check": "markdownlint-cli2 '**/*.{md,mdc}' '.*/**/*.{md,mdc}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "tsc": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^1.2.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint": "^0.40.0",
    "markdownlint-cli2": "^0.22.1",
    "oxfmt": "^0.47.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24"
  }
}
