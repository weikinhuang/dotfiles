{
  "name": "@weikinhuang/dotfiles",
  "version": "1.0.0",
  "private": true,
  "description": "My `$SHELL`, mostly bash, works everywhere, `*nix`, `osx`, `wsl`.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "oxlint": "oxlint --fix .",
    "prepare": "husky || true",
    "oxfmt": "oxfmt",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "markdownlint": "markdownlint-cli2 --fix '**/*.{md,mdc}' '.*/**/*.{md,mdc}'",
    "markdownlint:check": "markdownlint-cli2 '**/*.{md,mdc}' '.*/**/*.{md,mdc}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "tsc": "tsc --noEmit"
  },
  "devDependencies": {
    "@anthropic-ai/sandbox-runtime": "0.0.52",
    "@eslint/json": "^1.2.0",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint": "^0.40.0",
    "markdownlint-cli2": "^0.22.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24"
  }
}
