{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.dotfiles/config/claude/statusline-command.sh",
    "refreshInterval": 5
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(bat *)",
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(chmod *)",
      "Bash(cp *)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(echo *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(npx eslint *)",
      "Bash(printf *)",
      "Bash(pwd)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(sort *)",
      "Bash(tail *)",
      "Bash(tee *)",
      "Bash(touch *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(yamllint *)",
      "Bash(yq *)"
    ],
    "deny": ["Read(./.env.*)", "Read(./.env)", "Read(./.envrc)"]
  },
  "autoMemoryEnabled": true,
  "effortLevel": "high",
  "plansDirectory": "./plans",
  "prefersReducedMotion": false,
  "promptSuggestionEnabled": true,
  "terminalProgressBarEnabled": false,
  "theme": "auto",
  "tui": "fullscreen"
}
