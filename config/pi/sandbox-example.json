// Sandbox-only knobs for the kernel-level `sandbox` extension (Phase 3,
// not yet wired). Filesystem rules live in the unified
// `~/.pi/agent/filesystem.json` (see config/pi/filesystem-example.json).
//
//   Extension (Phase 3): config/pi/extensions/sandbox.ts
//   Reference (Phase 3): config/pi/extensions/sandbox.md
//   Pure helpers:        lib/node/pi/sandbox/{config-schema,config-load,
//                                              config-translate,active,
//                                              platform,linux-rules-compile,
//                                              violations-log,wrapper-slot}.ts
//
// Copy (or merge) into one of:
//
//   ~/.pi/agent/sandbox.json            - user scope, every project
//   <repo>/.pi/sandbox.json       - project scope, this repo only
//
// All fields are optional - omit to inherit the shipped defaults.
//
// IMPORTANT: this file does NOT control the standalone `srt` CLI.
// `srt` reads `~/.srt-settings.json`; pi reads `~/.pi/agent/sandbox.json`.
// Keep them separate so `srt` from a shell prompt has different
// policy from pi (deliberate, per plan decision #2).
//
// Mandatory write-denies layered on by the runtime (you cannot relax
// these from this file): ASRT's `DANGEROUS_FILES` basenames
// (`.gitconfig`, `.gitmodules`, `.bashrc`, `.bash_profile`, `.zshrc`,
// `.zprofile`, `.profile`, `.ripgreprc`, `.mcp.json`) and the
// directories from `getDangerousDirectories` (`.vscode`, `.idea`,
// `.claude/commands`, `.claude/agents`). The pi extension pre-creates
// empty stubs for these and for Claude Code's wider workspace pre-
// touch set (`.npmrc`, `.yarnrc*`, `bunfig.toml`, `package.json`,
// lockfiles) before every `wrapWithSandbox` to avoid a known bwrap
// mount-point race on concurrent bash tool calls. See
// `lib/node/pi/sandbox/dangerous-file-stubs.ts`. On Linux these stubs
// are transient host-side bwrap mount points that would otherwise show
// up as untracked files in `git status`; the `gitExcludeStubs` knob
// (below, default true) hides them via `<git-common-dir>/info/exclude`.
{
  "network": {
    // Domain ALLOW-list. Empty = deny all. Sandboxed bash that hits a
    // non-allowlisted domain triggers the network ask-callback (UI
    // dialog) or falls through to PI_SANDBOX_NETWORK_DEFAULT.
    //
    // Recipes (uncomment as needed):
    //   "allow": [
    //     "github.com",            // git push will publish to ANY repo
    //                              // your creds let you push to - tighten
    //                              // with a future MITM filterRequest hook
    //     "api.github.com",
    //     "registry.npmjs.org",
    //     "pypi.org",
    //     "files.pythonhosted.org",
    //     "127.0.0.1",             // localhost LLM (ollama, llama.cpp)
    //     "*.cloudfront.net"       // BROAD - many CDN domains share this
    //   ]
    "allow": [],

    // Explicit deny-list checked BEFORE the allow-list. Useful for
    // pinning a known-bad host even when its parent is allowed.
    "deny": []

    // KEEP-FILTERING way to reach host localhost services. When true,
    // `localhost` / `127.0.0.1` / `::1` are allow-listed and the wrapped
    // command's NO_PROXY is rewritten so loopback HTTP(S)/SOCKS traffic
    // routes through the sandbox proxy (which dials the host loopback).
    // Result: Docker published ports, a dev server, or a local LLM/API
    // on 127.0.0.1 become reachable WHILE every other domain is still
    // gated by `allow` / `deny` above. Prefer this over `unrestricted`.
    //
    // Covers tools that honor HTTP_PROXY / ALL_PROXY (curl, wget, pip,
    // npm, most HTTP clients). Does NOT cover raw-TCP clients that
    // ignore proxy env (psql, redis-cli, mysql, bare nc) - those need
    // `unrestricted`. No-op when `unrestricted` is set. Surface via
    // PI_SANDBOX_ALLOW_LOCALHOST=1. Off by default.
    // "allowLocalhost": false,

    // COARSE network escape hatch. When true, the kernel sandbox does
    // NOT isolate the network namespace, so sandboxed bash shares the
    // host network - including `localhost` / `127.0.0.1` host services
    // (Docker published ports, a dev server, a local DB). The tradeoff:
    // ALL domain filtering is OFF (the `allow` / `deny` lists above
    // become inert and every outbound destination is permitted).
    // Filesystem + unix-socket isolation are unaffected.
    //
    // Needed because on Linux ASRT uses `bwrap --unshare-net` (all-or-
    // nothing) whenever any allow-list is present, and hardcodes
    // `NO_PROXY=localhost,127.0.0.1,...` - so adding 127.0.0.1 to
    // `allow` does NOT make host loopback reachable; only turning
    // isolation off does. Prefer the narrower workarounds first:
    // `docker exec <container> ...`, or start + curl the service in ONE
    // bash command (shared namespace). Surface via
    // PI_SANDBOX_NETWORK_UNRESTRICTED=1 instead of editing the file for
    // a one-off session. Off by default.
    // "unrestricted": false
  },

  "unixSockets": {
    // Sockets sandboxed bash may connect to. Most users leave this
    // empty.
    //
    //   "/var/run/docker.sock"  -- effectively root-equivalent;
    //                              do not allow casually.
    //
    // PLATFORM NOTE: the `allow` path-list is honored ONLY on macOS
    // (sandbox-exec can match socket paths). On Linux, unix-socket
    // access is all-or-nothing: a seccomp-bpf filter blocks every
    // AF_UNIX socket and cannot inspect paths, so entries here are
    // SILENTLY IGNORED (you'll see a note in `/sandbox`). To reach
    // e.g. the docker socket on Linux you must set `allowAll` below,
    // which opens ALL unix sockets for that bash invocation.
    "allow": []

    // Opt out of socket sandboxing entirely (skips the seccomp
    // filter). REQUIRED on Linux to use any unix socket, including
    // docker.sock. Coarse - allows every unix socket, not just the
    // ones in `allow`. Surfaces a startup warning when set. Off by
    // default.
    // "allowAll": false
  },

  "flags": {
    // Required when pi runs inside Docker / nested containers.
    // Surface via PI_SANDBOX_NESTED=1 instead of editing the file.
    "weakerNestedSandbox": false,

    // macOS-only escape for Go programs that need TLS verification
    // (gh, gcloud, terraform, kubectl). Surface via
    // PI_SANDBOX_WEAKER_NET=1.
    "weakerNetworkIsolation": false,

    // macOS ONLY: allow sandboxed bash to reach 127.0.0.1 / localhost
    // (dev-server tests, a local DB, an LLM on 127.0.0.1) while still
    // filtering remote domains. sandbox-exec adds an allow-loopback rule
    // on top of `(deny default)`.
    //
    // HAS NO EFFECT ON LINUX. ASRT isolates the network with
    // `bwrap --unshare-net` (an empty network namespace) and never
    // forwards this flag to the Linux path, so it is a silent no-op
    // (you'll see a note in `/sandbox`). Per ASRT issue #43 the accepted
    // "set allowLocalBinding" answer is macOS-specific. To reach host
    // localhost services on Linux use `network.unrestricted` above
    // (coarse - drops all domain filtering) or the per-command
    // workarounds (`docker exec`, start + curl in ONE bash command).
    "allowLocalBinding": false,

    // Linux-only: bwrap accepts only literal paths, so basename /
    // segment rules from `filesystem.json` are compiled to existing
    // on-disk paths via `rg --files --max-depth N`. Default 3 covers
    // most workspaces; raise for deep monorepos. Bounded 1..10.
    "linuxRuleDepth": 3
  },

  // Hide the transient dangerous-file stubs (below) from `git status`
  // by maintaining a marked block in the repo's
  // `<git-common-dir>/info/exclude` (written on session start, stripped
  // on session end). Only names that are NOT git-tracked and are absent
  // or an empty stub are listed, so a real untracked file of the same
  // name (e.g. an 18-byte `.mcp.json` you authored) is never hidden.
  // Default true - the extra untracked files confuse weaker models.
  // Set false to leave the exclude file untouched; the env override
  // PI_SANDBOX_DISABLE_GIT_EXCLUDE=1 is a hard off-switch on top.
  "gitExcludeStubs": true
}
