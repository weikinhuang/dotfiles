{
  "baseUrl": "http://127.0.0.1:8188",
  "timeoutMs": 180000,
  "saveDir": ".pi/comfyui-out",
  "defaultWorkflow": "txt2img",
  "sendToModel": true,
  "background": false,
  "defaults": { "width": 1024, "height": 1024, "steps": 30, "cfg": 5, "count": 1, "negative": "blurry, lowres" },
  "authHeader": { "name": "Authorization", "value": "Bearer ${PI_COMFYUI_TOKEN}" },
