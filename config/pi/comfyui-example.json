{
  "baseUrl": "http://127.0.0.1:8188",
  "timeoutMs": 180000,
  "saveDir": ".pi/comfyui-out",
  "defaultWorkflow": "txt2img",
  "sendToModel": true,
  "background": false,
  "defaults": { "width": 1024, "height": 1024, "steps": 30, "cfg": 5, "count": 1, "negative": "blurry, lowres" },
  "authHeader": { "name": "Authorization", "value": "Bearer ${PI_COMFYUI_TOKEN}" },
  "workflows": {
    "txt2img": {
      "file": "~/.dotfiles/config/pi/comfyui/txt2img.api.json",
      "inputs": {
        "prompt": { "node": "6", "key": "text" },
        "negative": { "node": "7", "key": "text" },
        "seed": { "node": "3", "key": "seed" },
        "steps": { "node": "3", "key": "steps" },
        "cfg": { "node": "3", "key": "cfg" },
        "width": { "node": "5", "key": "width" },
        "height": { "node": "5", "key": "height" },
        "batch": { "node": "5", "key": "batch_size" }
      }
    },
    "img2img": {
      "file": "~/.dotfiles/config/pi/comfyui/img2img.api.json",
      "inputs": {
        "prompt": { "node": "6", "key": "text" },
        "negative": { "node": "7", "key": "text" },
        "image": { "node": "10", "key": "image" },
        "denoise": { "node": "3", "key": "denoise" },
        "seed": { "node": "3", "key": "seed" },
        "steps": { "node": "3", "key": "steps" },
        "cfg": { "node": "3", "key": "cfg" }
      }
    },
    "qwen-image-edit": {
      "file": "~/.dotfiles/config/pi/comfyui/qwen-image-edit.api.json",
      "inputs": {
        "prompt": { "node": "6", "key": "prompt" },
        "image": { "node": "41", "key": "image" },
        "denoise": { "node": "3", "key": "denoise" },
        "seed": { "node": "3", "key": "seed" },
        "steps": { "node": "3", "key": "steps" }
      }
    }
  }
}
