{
  "37": {
    "class_type": "UNETLoader",
    "_meta": { "title": "Load Diffusion Model (FLUX.1 Kontext dev, fp8)" },
    "inputs": {
      "unet_name": "flux1-dev-kontext_fp8_scaled.safetensors",
      "weight_dtype": "default"
    }
  },
  "38": {
    "class_type": "DualCLIPLoader",
    "_meta": { "title": "DualCLIPLoader (clip_l + t5xxl, Flux)" },
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5xxl_fp8_e4m3fn_scaled.safetensors",
      "type": "flux",
      "device": "default"
    }
  },
  "39": {
    "class_type": "VAELoader",
    "_meta": { "title": "Load VAE (Flux autoencoder)" },
    "inputs": { "vae_name": "ae.safetensors" }
  },
  "41": {
    "class_type": "LoadImage",
    "_meta": { "title": "Load Source Image" },
    "inputs": { "image": "example.png" }
  },
  "42": {
    "class_type": "FluxKontextImageScale",
    "_meta": { "title": "Flux Kontext Image Scale (snap source to a supported edit resolution)" },
    "inputs": { "image": ["41", 0] }
  },
  "44": {
    "class_type": "VAEEncode",
    "_meta": { "title": "VAE Encode (source image -> reference latent)" },
    "inputs": { "pixels": ["42", 0], "vae": ["39", 0] }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "CLIP Text Encode (Edit Instruction)" },
    "inputs": {
      "text": "change the background to a sunny beach, keep the subject unchanged",
      "clip": ["38", 0]
    }
  },
  "35": {
    "class_type": "FluxGuidance",
    "_meta": { "title": "Flux Guidance (edit strength; this is Flux's real guidance knob, not KSampler cfg)" },
    "inputs": { "guidance": 2.5, "conditioning": ["43", 0] }
  },
  "43": {
    "class_type": "ReferenceLatent",
    "_meta": { "title": "Reference Latent (anchor the edit to the source image)" },
    "inputs": { "conditioning": ["6", 0], "latent": ["44", 0] }
  },
  "40": {
    "class_type": "ConditioningZeroOut",
    "_meta": { "title": "Conditioning Zero Out (empty negative for cfg 1)" },
    "inputs": { "conditioning": ["6", 0] }
  },
  "3": {
    "class_type": "KSampler",
    "_meta": { "title": "KSampler" },
    "inputs": {
      "seed": 0,
      "steps": 20,
      "cfg": 1,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1,
      "model": ["37", 0],
      "positive": ["35", 0],
      "negative": ["40", 0],
      "latent_image": ["44", 0]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" },
    "inputs": { "samples": ["3", 0], "vae": ["39", 0] }
  },
  "9": {
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" },
    "inputs": { "filename_prefix": "pi", "images": ["8", 0] }
  }
}
