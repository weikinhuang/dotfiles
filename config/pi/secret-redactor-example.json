{
  // secret-redactor config. Copy to ~/.pi/agent/secret-redactor.json (global)
  // or <repo>/.pi/secret-redactor.json (project). Both stack; project wins.
  // All keys optional - this file shows every knob with its default.

  // Detection layers. `prefixed` = fixed-prefix provider tokens (AWS, GitHub,
  // OpenAI, ...). `keyword` = `<sensitive-key>=<value>` + Authorization headers
  // + connection strings. `entropy` is reserved (not yet implemented).
  "layers": { "prefixed": true, "keyword": true, "entropy": false },

  // Project-specific secret formats, augmenting the built-in corpus. A pattern
  // with a capture group redacts the value (group 1) and is value-guarded; a
  // group-less pattern redacts the whole match. `id` becomes the placeholder
  // label, e.g. [REDACTED:acme-api-key#1a2b].
  "rules": [
    { "id": "acme-api-key", "pattern": "ACME-[0-9a-f]{32}" }
    // { "id": "internal-kv", "pattern": "internal_secret=([A-Za-z0-9._-]{16,})" }
  ],

  // Regexes for values that should NEVER be redacted (false-positive escape
  // hatch). Checked before any rule fires. Built-in allowlist already covers
  // git SHAs, UUIDs, ISO timestamps, and lockfile integrity hashes.
  "allowlist": ["\\bACME-PUBLIC-[0-9a-f]+\\b"],

  // Minimum value length for keyword-style matches (guards against redacting
  // short, non-secret assignments).
  "keywordMinLength": 8
}
