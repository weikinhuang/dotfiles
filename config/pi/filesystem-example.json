// Baseline filesystem-policy config consumed by both the in-process
// `filesystem` extension (read / write / edit) and the kernel-level
// `sandbox` extension via @anthropic-ai/sandbox-runtime.
//
//   Pure helpers: lib/node/pi/filesystem-policy/{schema,load,classify}.ts
//   Translator:   lib/node/pi/sandbox/config-translate.ts
//
// Copy (or merge) into one of:
//
//   ~/.pi/agent/filesystem.json         - user scope, every project
//   <repo>/.pi/filesystem.json    - project scope, this repo only
//
// Schema recap (full rules in plan section 4.2):
//
//   read.deny.{basenames,segments,paths}     block reads
//   read.allow.{basenames,segments,paths}    allow-back inside a deny prefix
//   write.allow.paths                        OUTER GATE - writes outside
//                                            denied. NOT a carve-back.
//   write.allow.{basenames,segments}         CARVE-BACK inside write.deny
//                                            (mirrors read.allow). Lets a
//                                            stricter project policy say
//                                            "deny node_modules writes
//                                            EXCEPT under
//                                            node_modules/.vite-temp".
//   write.deny.{basenames,segments,paths}    carve holes inside the
//                                            allowed area.
//
// Every rule supports tilde expansion (`~/...`) and segment expressions
// like `.git/hooks` (matches the directory and everything under it).
{
  "read": {
    // Block reads of anything that holds secrets, private keys, or
    // cloud creds. The in-process gate prompts; the kernel sandbox
    // returns EACCES so even `cat ~/.ssh/id_rsa` from a smuggled
    // `sh -c "..."` is denied at the syscall.
    "deny": {
      // `.netrc` matches the additional sensitive-file basename Claude
      // Code stubs in its `assertScrubSandboxAvailable` pre-touch list;
      // its presence here keeps `curl --netrc` credentials out of model
      // reads even when no user policy adds it.
      "basenames": [".env", ".env.*", ".envrc", ".netrc"],
      "segments": [],
      "paths": ["~/.ssh", "~/.aws", "~/.gnupg", "~/.config/gh", "~/.kube", "~/.docker/config.json"]
    },

    // Carve narrow holes inside the deny set. Empty by default.
    // Example: "allow back" `~/.config/gh/hosts.yml` only:
    //   "allow": { "paths": ["~/.config/gh/hosts.yml"] }
    "allow": {
      "basenames": [],
      "segments": [],
      "paths": []
    }
  },

  "write": {
    // ALLOW-ONLY for writes. `paths` is the OUTER GATE: anything
    // outside is denied at BOTH layers. The default `"."` covers the
    // workspace (the session's `ctx.cwd`, NOT `process.cwd()`); `/tmp`
    // keeps throwaway scripts working. Persona `writeRoots` merge on
    // top at runtime.
    //
    // `basenames` and `segments` here act as CARVE-BACK inside the
    // deny set (NOT extra outer-gate roots). Example use, ONLY if a
    // project policy also adds `node_modules` to write.deny.segments:
    //   "segments": ["node_modules/.vite-temp", "node_modules/.vite"]
    // The in-process gate honors carve-back exactly. The kernel
    // sandbox can't allow-back inside a deny via ASRT, so the matching
    // kernel deny is RELAXED for the whole shadowed segment - look for
    // a lossy note in `/sandbox` saying "kernel write-deny on segment
    // X relaxed by a write.allow.segments carve-back" if that matters.
    "allow": {
      "basenames": [],
      "segments": [],
      "paths": [".", "/tmp"]
    },

    // Hole-poke inside `write.allow`. `.git/hooks` and `.git/config`
    // are mandatory to keep models from rewriting hooks (a known
    // exfil trick). ASRT layers on its own mandatory write-denies for
    // every Linux wrap regardless of this file: the basenames in
    // `DANGEROUS_FILES` (`.gitconfig`, `.gitmodules`, `.bashrc`,
    // `.bash_profile`, `.zshrc`, `.zprofile`, `.profile`, `.ripgreprc`,
    // `.mcp.json`) and the directories from `getDangerousDirectories`
    // (`.vscode`, `.idea`, `.claude/commands`, `.claude/agents`). Pi
    // pre-creates stubs for those at the start of every wrap to avoid
    // an ASRT bwrap mount-point race; see `lib/node/pi/sandbox/
    // dangerous-file-stubs.ts`.
    //
    // `node_modules` is NOT denied by default - workspaces are
    // write-allowed via `write.allow.paths: ["."]`, so dependency
    // installs work without prompting. Projects that want a stricter
    // stance can add it back:
    //   "segments": [".git/hooks", ".git/config", "node_modules"]
    // If you do, the reactive fs-ask dialog (see sandbox.md) will
    // prompt you to allow writes back per-session or per-project the
    // first time bash hits the deny.
    //
    // The kernel sandbox enforces these on Linux (bwrap overlay).
    // On macOS, sandbox-exec silently DROPS deny rules pointing at
    // not-yet-existing files - the in-process gate still blocks
    // them lexically. See plan section 9.20.
    "deny": {
      "basenames": [".env", ".env.*"],
      "segments": [".git/hooks", ".git/config"],
      "paths": []
    }
  }
}
