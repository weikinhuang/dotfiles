// Baseline **read-only** allow-list for the `bash-permissions` extension.
//
//   Extension:  config/pi/extensions/bash-permissions.ts
//   Reference:  config/pi/extensions/bash-permissions.md
//
// Copy (or merge) into one of:
//
//   ~/.pi/bash-permissions.json       - user scope, every project
//   <repo>/.pi/bash-permissions.json  - project scope, this repo only
//
// Semantics recap (full rules in bash-permissions.md):
//   - `foo`         exact match
//   - `foo*`        token-aware prefix (`git log*` ≠ `git logs`)
//   - `re:<regex>`  unanchored JS regex (anchor with ^…$ for whole-command match)
//   - `/re/flags`   JS regex with flags
//   - Compound commands joined by &&, ||, ; are split and each side must pass
//   - Deny beats allow across session / project / user layers
//
// Everything below either prints, lists, searches, or inspects state. Nothing
// here mutates the filesystem, repo history, packages, containers, or network.
// Add your own write/build commands in a separate file - don't muddy this one.
{
  "allow": [
    // ── file inspection ────────────────────────────────────────────────────
    "ls*",
    "pwd",
    "cat*",
    // `bat` is a `cat` replacement; same read-only use case, but it has
    // two mutation vectors we reject via regex:
    //   * `bat cache ...`    builds / clears the syntax-and-theme cache
    //   * `bat --write-config` / `--generate-config-file`    writes config
    // Everything else - `bat file`, `bat --plain`, `bat --list-languages`,
    // `bat --paging=never`, etc. - stays allowed.
    "re:^bat(?!\\s+cache\\b)(?!.*\\s(--write-config|--generate-config-file)\\b)(\\s.*)?$",
    "head*",
    "tail*",
    "file*",
    "stat*",
    "wc*",
    "du*",
    "df*",
    "tree*",
    "readlink*",
    "realpath*",
    "basename*",
    "dirname*",
    "which*",
    "type*",
    "command -v*",

    // ── search ─────────────────────────────────────────────────────────────
    // `find`, `fd`, and `rg` each have a flag that pivots them from "search"
    // to "run an arbitrary subcommand per match" (or, in find's case, mutate
    // the filesystem). Prefix matches like `find*` would let those through,
    // so the three are gated by regex instead.
    //   find: -exec / -execdir / -ok / -okdir run commands;
    //         -delete removes files; -fprint / -fprintf / -fls write to a file.
    //   fd:   -x / -X / --exec / --exec-batch run commands.
    //   rg:   --pre <cmd> runs a preprocessor per matched file.
    "re:^find(?!.*\\s-(exec|execdir|ok|okdir|delete|fprint|fprintf|fls)\\b)(\\s.*)?$",
    "re:^fd(?!.*\\s(-x|-X|--exec|--exec-batch)\\b)(\\s.*)?$",
    "re:^rg(?!.*\\s--pre(\\s|=))(\\s.*)?$",
    "grep*",
    "egrep*",
    "fgrep*",
    "ag*",
    "locate*",

    // ── git: read-only subcommands ─────────────────────────────────────────
    "git status*",
    "git log*",
    "git show*",
    "git diff*",
    "git blame*",
    "git reflog*",
    "git describe*",
    "git rev-parse*",
    "git rev-list*",
    "git ls-files*",
    "git ls-tree*",
    "git cat-file*",
    "git shortlog*",
    "git grep*",
    "git remote",
    "git remote -v",
    "git remote show*",
    "git remote get-url*",
    "git stash list*",
    "git stash show*",
    "git worktree list*",
    "git submodule status*",
    // `git branch` lists; `git branch <name>` CREATES. Allow only list-y forms.
    "re:^git branch(\\s+(-[alrvv]+|--all|--remotes|--show-current|--list( .+)?|--contains( .+)?|--merged( .+)?|--no-merged( .+)?))*\\s*$",
    // Same story for `git tag`.
    "re:^git tag(\\s+(-l|--list)( .+)?)?\\s*$",
    // `git config --list` / `--get…` are read-only; bare `git config key value` writes.
    "re:^git config\\s+(--list|--get|--get-all|--get-regexp)(\\s+.+)?$",

    // ── gh: read-only subcommands ──────────────────────────────────────────
    // GitHub CLI read-only queries. Token-aware prefix or regex; nothing
    // here mutates remote state.
    //
    // Deliberately NOT in this list (hit the approval prompt instead -
    // opt in per repo via `<repo>/.pi/bash-permissions.json`):
    //   gh pr create / merge / close / edit / comment / review
    //   gh issue create / close / edit / comment
    //   gh release create / edit / delete
    //   gh workflow run
    //   gh run cancel / rerun / delete
    "gh repo view*",
    "gh pr view*",
    "gh pr list*",
    "gh pr diff*",
    "gh pr checks*",
    "gh pr status*",
    "gh issue view*",
    "gh issue list*",
    "gh issue status*",
    "gh run view*",
    "gh run list*",
    "gh run watch*",
    "gh release view*",
    "gh release list*",
    "gh workflow view*",
    "gh workflow list*",
    "gh search *",
    "gh status*",
    "gh auth status*",
    "gh config get*",
    "gh config list*",
    "gh label list*",
    "gh ruleset list*",
    "gh variable list*",
    "gh secret list*",
    "gh browse*",
    // `gh api` defaults to GET. Two lookaheads turn this into a
    // read-only gate:
    //   * first rejects any explicit non-GET method (`-X POST`,
    //     `--method DELETE`, etc.) - leaves bare `gh api <path>`
    //     and `gh api graphql` (which default to GET) untouched.
    //   * second rejects any field arg (`-f`, `-F`, `--field`,
    //     `--raw-field`) - field args only make sense for mutations,
    //     including graphql mutations that pass `-f query=mutation{…}`.
    "re:^gh api(?!.*\\s(-X|--method)\\s+(POST|PATCH|PUT|DELETE))(?!.*\\s(-f|-F|--field|--raw-field)\\b)(\\s.*)?$",

    // ── glab: read-only subcommands ────────────────────────────────────────
    // GitLab CLI read-only queries. Same shape as the `gh` block above.
    //
    // Deliberately NOT in this list (hit the approval prompt instead -
    // opt in per repo via `<repo>/.pi/bash-permissions.json`):
    //   glab mr create / merge / close / update / note
    //   glab issue create / close / update / note
    //   glab release create / delete
    //   glab ci run / retry / cancel / delete
    "glab mr view*",
    "glab mr list*",
    "glab mr diff*",
    "glab mr checkout*",
    "glab issue view*",
    "glab issue list*",
    "glab ci view*",
    "glab ci list*",
    "glab ci status*",
    "glab ci trace*",
    "glab release view*",
    "glab release list*",
    "glab repo view*",
    "glab repo search*",
    "glab auth status*",
    "glab config get*",
    "glab label list*",
    "glab variable list*",
    // `glab api` mirrors `gh api`: defaults to GET, mutations require
    // an explicit `--method` / `-X` or a field arg, both rejected here.
    "re:^glab api(?!.*\\s(--method|-X)\\s+(POST|PATCH|PUT|DELETE))(?!.*\\s(-f|-F|--field|--raw-field)\\b)(\\s.*)?$",

    // ── node / package managers: read-only queries ─────────────────────────
    "node --version",
    "node -v",
    "npm --version",
    "npm -v",
    "npm list*",
    "npm ls*",
    "npm outdated*",
    "npm view*",
    "npm info*",
    "npm config get*",
    "npm config list*",
    "npx --version",
    "yarn --version",
    "yarn list*",
    "yarn why*",
    "pnpm --version",
    "pnpm list*",
    "pnpm why*",

    // ── containers: read-only queries ──────────────────────────────────────
    "docker ps*",
    "docker images*",
    "docker image ls*",
    "docker container ls*",
    "docker logs*",
    "docker inspect*",
    "docker version",
    "docker info",
    "docker stats --no-stream*",

    // ── directory navigation ───────────────────────────────────────────────
    // Each `bash` tool call runs in its own subshell, so a bare `cd foo`
    // doesn't persist across calls. These rules matter because compound
    // commands are split on `&&`, `||`, `;`, and each side is checked
    // independently - `cd sub && run-thing` would otherwise be blocked
    // at the `cd sub` half.
    //
    // Known quirk: `(cd sub && cmd)` splits into `['(cd sub', 'cmd)']`,
    // so the opening paren sticks to the token and breaks the prefix
    // match. Use `cd sub && cmd` (no subshell parens) or rely on the
    // caller's cwd instead.
    "cd*",
    "pushd*",
    "popd*",
    "dirs*",

    // ── shell builtins / conditionals ─────────────────────────────────────────────
    // `set`, `shopt`, `alias` toggle shell state that is scoped to the
    // subshell pi spawns for this tool call - the state vanishes on
    // exit, so these can't be used to persist a surprise side effect
    // across calls. `test` / `[` are pure predicate builtins.
    "set*",
    "shopt*",
    "alias",
    "alias -p",
    "test*",
    "[*",
    // `[[ ... ]]` (conditional expression) and `(( ... ))` (arithmetic
    // evaluation) are bash keywords, not commands - they're parsed by
    // the shell directly and have no exec vector of their own. Still
    // subject to the generic command-substitution caveat every `*` rule
    // has (`[[ -n "$(rm -rf /)" ]]` is blocked by the hardcoded denylist
    // on the `rm` side, not here).
    "[[*",
    "((*",
    // Control-flow constructs whose args aren't executable commands
    // (their bodies are - and those run through the gate independently
    // after `decideSubcommand`'s control-flow-keyword strip peels off
    // any leading `if`/`while`/`then`/…). `for VAR in LIST` / `select`
    // / `case EXPR in` all need an explicit allow here because their
    // first-token form isn't covered by any other rule.
    "for*",
    "select*",
    "case*",

    // ── text processing (readonly stream transforms) ──────────────────────────────
    // Every tool here reads from stdin/argv and writes to stdout only -
    // no in-place edits, no exec vectors. `sort` is the exception:
    // `sort -o FILE` writes to FILE, so it's admitted via regex that
    // rejects `-o`.
    //
    // Deliberately NOT in this list:
    //   awk    - `system()` and `| "cmd"` run shell commands
    //   yq     - `-i` / `--inplace` writes files
    //   xargs  - universal pipe-to-arbitrary-command
    //   less / more  - interactive pagers that can execute `!cmd`
    //
    // `sed` is admitted via regex - `-i` (in any bundle) and `--in-place`
    // are rejected, but the GNU-sed `e` / `w` script commands live inside
    // the quoted script argument and aren't parseable from out here. Use
    // `sed` for read-only transformations only; author sed scripts
    // containing `e` or `w` at your own risk.
    "re:^sed(?!.*\\s(-[a-zA-Z]*i[a-zA-Z]*|--in-place)\\b)(\\s.*)?$",
    "re:^sort(?!.*\\s(-o|--output)\\b)(\\s.*)?$",
    "cut*",
    "uniq*",
    "tr*",
    "nl*",
    "tac*",
    "rev",
    "fold*",
    "fmt*",
    "column*",
    "paste*",
    "join*",
    "comm*",
    "diff*",
    "cmp*",
    "jq*",

    // ── hashing / encoding / binary inspection (stdout-only) ──────────────────────
    "md5sum*",
    "sha1sum*",
    "sha256sum*",
    "sha512sum*",
    "shasum*",
    "b2sum*",
    "cksum*",
    "base64*",
    "xxd*",
    "od*",
    "hexdump*",

    // ── system / env info ──────────────────────────────────────────────────
    "echo*",
    "printf*",
    "env",
    "printenv*",
    "date*",
    "uname*",
    "whoami",
    "hostname*",
    "id",
    "id -u",
    "id -g",
    "uptime",
    "ps*",
    "true",
    "false"
  ],

  // Additive deny list. The extension already hardcodes catastrophes
  // (`rm -rf /`, fork bombs, `mkfs`, raw `dd`, `curl | sh`, …) and the
  // `filesystem` extension guards `.env*` / `~/.ssh` / `.git/` / etc.
  // Add entries here only when you want belt-and-suspenders for a specific
  // command on this machine or repo.
  //
  // The forge-CLI entries below would already fall through to the approval
  // prompt (no allow match), but their blast radius is irreversible enough
  // that we deny them outright as belt-and-suspenders.
  "deny": [
    "gh repo delete*", // irreversible: deletes the GitHub repository
    "gh auth login*", // rewrites token storage / initiates an OAuth flow
    "gh auth logout*", // wipes stored credentials
    "gh secret set*", // writes a repo / org / env secret
    "gh ssh-key add*", // attaches an SSH key to the account
    "gh gpg-key add*", // attaches a GPG key to the account
    "gh extension install*", // installs third-party code into the gh CLI
    "glab repo delete*", // irreversible: deletes the GitLab project
    "glab auth login*", // rewrites token storage / initiates an OAuth flow
    "glab auth logout*", // wipes stored credentials
    "glab variable set*", // writes a CI/CD variable
    "glab variable delete*", // removes a CI/CD variable
    "glab config set*", // mutates persistent glab config
    "glab extension install*" // installs third-party code into the glab CLI
  ]
}
