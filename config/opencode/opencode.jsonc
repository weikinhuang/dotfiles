{
  "$schema": "https://opencode.ai/config.json",
  "model": "",
  "small_model": "",
  "command": {
  },
  "provider": {
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
  ],
  "mcp": {
    "sequential-thinking": {
      "enabled": true,
      "type": "local",
      "command": ["docker", "run", "--rm", "-i", "mcp/sequentialthinking"],
    },
    "time": {
      "enabled": true,
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "LOCAL_TIMEZONE",
        "mcp/time",
      ],
    },
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        // "CONTEXT7_API_KEY": ""
      },
    },
  },
}

