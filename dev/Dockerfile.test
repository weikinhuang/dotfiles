# syntax=docker/dockerfile:1
FROM ubuntu:24.04

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN set -ex \
    && export DEBIAN_FRONTEND=noninteractive \
    && apt-get update -qq \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        gnupg \
    # NodeSource provides a recent Node; Ubuntu's apt ships 18.x which is
    # too old for built-in TypeScript type-stripping and the node:sqlite
    # module used by the session-usage tooling.
    && curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y --no-install-recommends \
        # test framework
        bats \
        bats-assert \
        bats-support \
        # linting
        shellcheck \
        shfmt \
        # used by tests (skip-guarded)
        gawk \
        neovim \
        nodejs \
        perl \
        powerline \
        tmux \
        vim \
        # general utilities
        git \
        jq \
        sudo \
        tini \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /dotfiles

ENTRYPOINT [ "tini", "-s", "-g", "--" ]

LABEL org.opencontainers.image.authors="Wei Kin Huang"
LABEL org.opencontainers.image.description="My \$SHELL, mostly bash, works everywhere, *nix, osx, wsl."
LABEL org.opencontainers.image.documentation="https://github.com/weikinhuang/dotfiles/blob/master/README.md"
LABEL org.opencontainers.image.source="https://github.com/weikinhuang/dotfiles"
LABEL org.opencontainers.image.title="dotfiles"
LABEL org.opencontainers.image.vendor="Wei Kin Huang"
LABEL org.opencontainers.image.version="1.0.0"
