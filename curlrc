# When following a redirect, automatically set the previous URL as referer.
referer = ";auto"

# Follow HTTP redirects (3xx responses), but cap the chain to avoid loops.
location
max-redirs = 10

# Wait 60 seconds before timing out.
connect-timeout = 60

# Retry transient failures (uses exponential backoff by default).
retry = 3
retry-max-time = 60

# Also retry when the connection is refused (mirrors wgetrc retry_connrefused).
retry-connrefused

# Request compressed responses and transparently decompress them.
compressed

# Default to HTTPS when no scheme is given.
proto-default = https

# Refuse to negotiate anything older than TLS 1.2.
tlsv1.2

# Set the saved file's timestamp from the server (mirrors wgetrc timestamping).
remote-time
