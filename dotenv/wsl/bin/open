#!/usr/bin/env bash
#title              : open
#description        : Alias to winstart, cross-platform "start" command
#author             : Wei Kin Huang
#date               : 2022-06-07
#version            : 1.0.0
#usage              : open [args...]
#requires           : powershell.exe
#===============================================================================
set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: open [OPTION]... [PATH-OR-URL...]
Open files, paths, or URLs with the Windows default handler via winstart.

Options:
  -h, --help                  show this help and exit

All remaining arguments are forwarded to winstart.
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

exec winstart "$@"
