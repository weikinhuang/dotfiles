#!/usr/bin/env bash
# Open paths with the native Windows handler from WSL.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: open [OPTION]... [PATH-OR-URL...]
Open files, paths, or URLs with the Windows default handler via winstart.

Options:
  -h, --help                  show this help and exit

All remaining arguments are forwarded to winstart.
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

exec winstart "$@"
