#!/usr/bin/env bash
#title              : is-elevated-session
#description        : Checks if the current process (sesison) is running with Administrator privileges.
#author             : Wei Kin Huang
#date               : 2022-05-26
#version            : 1.0.0
#usage              : is-elevated-session [args...]
#requires           : powershell.exe
#===============================================================================
set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: is-elevated-session [OPTION]...
Exit successfully when the current Windows session has Administrator privileges.

Options:
  -h, --help                  show this help and exit

Exit status 0 indicates Administrator privileges.
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

# try using powershell to determine elevated status
if ! out="$(powershell.exe -NoProfile -NonInteractive -Command '(New-Object Security.Principal.WindowsPrincipal([Security.Principal.WindowsIdentity]::GetCurrent())).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)' </dev/null 2>/dev/null | tr -d '\r')"; then
  exit 255
fi
test "${out}" == "True"
