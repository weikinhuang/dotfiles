#!/usr/bin/env bash
#title              : winsudo
#description        : Run commands with elevated Windows privileges from WSL
#author             : Wei Kin Huang
#date               : 2018-10-13
#version            : 2.0.0
#usage              : winsudo [-v] [args...]
#requires           : sudo.exe (Windows 11 24H2+) or powershell.exe net.exe nc ssh sshd wslpath
#
# Prefers native Windows sudo.exe when available and configured for inline
# mode (Windows 11 24H2+). Falls back to an SSH-based elevation mechanism
# for older Windows versions.
#
# Native sudo setup:
#   1. Enable sudo in Windows Settings > System > Advanced
#   2. Set inline mode: sudo config --enable normal
#   3. Verify: sudo config  (should report "Inline mode")
#
# Legacy fallback (pre-24H2):
#   Requires openssh-server. Uses PowerShell Start-Process -Verb RunAs to
#   launch an elevated WSL sshd instance, then tunnels commands over SSH.
#   Any process that works under ssh should work with this fallback.
#===============================================================================

set -euo pipefail
IFS=$'\n\t'

SCRIPT_NAME="$(basename "$0")"
WINSUDO_VERBOSE=""

function print_help() {
  cat <<'EOF'
Usage: winsudo [OPTION]... [COMMAND [ARG...]]
Run Windows commands with elevated privileges from WSL.

Options:
  -v                          enable verbose fallback diagnostics
  -h, --help                  show this help and exit

With no COMMAND, starts an elevated login shell.
Remaining arguments are treated as the command to elevate.
EOF
}

#===============================================================================
# native sudo functions
#===============================================================================

function internal::has-native-sudo() {
  command -v sudo.exe &>/dev/null
}

function internal::check-sudo-inline() {
  local config_output
  config_output="$(sudo.exe config 2>/dev/null | tr -d '\r')" || return 1
  [[ "${config_output}" == *"Inline"* ]]
}

function internal::validate-native-sudo() {
  if ! internal::has-native-sudo; then
    return 1
  fi
  if ! internal::check-sudo-inline; then
    if [[ -n "${WINSUDO_VERBOSE}" ]]; then
      echo "winsudo: Windows sudo is available but not in inline mode." >&2
      echo "winsudo: Set inline mode with: sudo config --enable normal" >&2
      echo "winsudo: Falling back to legacy SSH-based elevation." >&2
    fi
    return 1
  fi
  return 0
}

function internal::native-sudo() {
  if [[ $# -eq 0 ]]; then
    exec sudo.exe wsl.exe -e bash -l
  else
    exec sudo.exe "$@"
  fi
}

#===============================================================================
# legacy ssh-based elevation
#===============================================================================

function internal::legacy-init() {
  SSHD_PID_PORT=$((($$ % 33314) + 32222))
  WINSUDO_WORKDIR="${HOME}/.ssh/winsudosshd"
  if command -v powershell.exe &>/dev/null; then
    POWERSHELL_EXEC="$(command -v powershell.exe)"
  else
    POWERSHELL_EXEC="$(wslpath -u c:)/Windows/System32/WindowsPowerShell/v1.0/powershell.exe"
  fi
  if ! command -v sshd &>/dev/null; then
    if [[ -n "${WINSUDO_VERBOSE}" ]]; then
      echo "winsudo: legacy fallback requires openssh-server (sshd not found in PATH)" >&2
      echo "winsudo: install with: sudo apt-get install openssh-server" >&2
      echo "winsudo: or enable native Windows sudo: sudo config --enable normal" >&2
    fi
    return 1
  fi
  SSHD_EXEC="$(command -v sshd)"

  trap internal::cleanup EXIT
}

function internal::is-elevated-process() {
  local ret out

  out="$("${POWERSHELL_EXEC}" -c '(New-Object Security.Principal.WindowsPrincipal([Security.Principal.WindowsIdentity]::GetCurrent())).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)' </dev/null | tr -d '\r')"
  ret=$?
  test ${ret} -eq 0 && test "${out}" == "True"
}

function internal::cleanup() {
  if [[ -z "${WINSUDO_WORKDIR:-}" || -z "${SSHD_PID_PORT:-}" ]]; then
    return 0
  fi
  if [[ ! -e "${WINSUDO_WORKDIR}/winsudo.${SSHD_PID_PORT}.pid" ]]; then
    return 0
  fi
  kill "$(cat "${WINSUDO_WORKDIR}/winsudo.${SSHD_PID_PORT}.pid")" || true
  rm -f "${WINSUDO_WORKDIR}/winsudo.${SSHD_PID_PORT}.pid"
}

function internal::ssh-gen-keys() {
  if [[ ! -d "${WINSUDO_WORKDIR}" ]]; then
    mkdir -p ~/.ssh/winsudosshd
  fi
  if [[ ! -e "${WINSUDO_WORKDIR}/ssh_host_ed25519_key" ]]; then
    ssh-keygen -q -N "" -t ed25519 -f "${WINSUDO_WORKDIR}/ssh_host_ed25519_key"
  fi
  if [[ ! -e "${WINSUDO_WORKDIR}/authorized_keys" ]] || [[ ! -e "${WINSUDO_WORKDIR}/ssh_ed25519_key" ]]; then
    rm -f "${WINSUDO_WORKDIR}/ssh_ed25519_key"
    ssh-keygen -q -N "" -t ed25519 -f "${WINSUDO_WORKDIR}/ssh_ed25519_key"
    cat "${WINSUDO_WORKDIR}/ssh_ed25519_key.pub" >|"${WINSUDO_WORKDIR}/authorized_keys"
  fi
}

function internal::escape-args() {
  if [[ $# == 0 ]]; then
    return
  fi
  local args=()
  for arg in "$@"; do
    # clean up weird windows \r line ending issue
    args+=("$(printf '%q' "$arg" | sed "s/\\\\r'\$/'/")")
  done
  echo "${args[@]}"
}

function internal::ssh() {
  local SSH_OPTIONS=(
    -q
    -o "UserKnownHostsFile=/dev/null"
    -o "StrictHostKeyChecking=no"
    -o "ConnectTimeout=5"
    -i "${WINSUDO_WORKDIR}/ssh_ed25519_key"
    -p "${SSHD_PID_PORT}"
  )

  if [[ ! -t 0 && ! -t 1 ]]; then
    ssh "${SSH_OPTIONS[@]}" 127.0.0.1 -- "$@"
  else
    ssh "${SSH_OPTIONS[@]}" -t 127.0.0.1 -- "$@"
  fi
}

function internal::ssh-with-cwd() {
  internal::ssh cd "$(printf '%q' "$(pwd)")" \&\>/dev/null\ \|\|\ true\ \; "$@"
}

function internal::ssh-with-login() {
  internal::ssh-with-cwd BASHRC_NONINTERACTIVE_BYPASS=1 source \~/.bashrc \&\>/dev/null\ \|\|\ true\ \; "$@"
}

function internal::start-privileged-server() {
  if ! "${POWERSHELL_EXEC}" \
    Start-Process \
    -Verb RunAs \
    -WindowStyle Hidden \
    wsl.exe \"bash\", \""$(realpath "$(command -v "${SCRIPT_NAME}")")"\", \"--privileged\", \"${SSHD_PID_PORT}\" </dev/null &>/dev/null; then
    echo "UAC elevation was canceled" >&2
    return 1
  fi

  while ! nc -z 127.0.0.1 ${SSHD_PID_PORT}; do
    sleep 0.1
  done
}

#===============================================================================
# legacy entrypoint functions
#===============================================================================

function internal::privileged-process() {
  local PARENT_PID_PORT="$1"
  SSHD_PID_PORT="${PARENT_PID_PORT}"

  if ! internal::is-elevated-process </dev/null &>/dev/null; then
    return 1
  fi

  # https://infosec.mozilla.org/guidelines/openssh
  "${SSHD_EXEC}" -D \
    -f /dev/null \
    -p "${PARENT_PID_PORT}" \
    -o AuthenticationMethods=publickey \
    -o AuthorizedKeysFile="${WINSUDO_WORKDIR}/authorized_keys" \
    -o Ciphers="chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com,aes256-ctr,aes192-ctr,aes128-ctr" \
    -o HostKey="${WINSUDO_WORKDIR}/ssh_host_ed25519_key" \
    -o KexAlgorithms="curve25519-sha256@libssh.org,ecdh-sha2-nistp521,ecdh-sha2-nistp384,ecdh-sha2-nistp256,diffie-hellman-group-exchange-sha256" \
    -o ListenAddress=127.0.0.1 \
    -o MACs="hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,umac-128-etm@openssh.com,hmac-sha2-512,hmac-sha2-256,umac-128@openssh.com" \
    -o MaxSessions=1 \
    -o PermitRootLogin=No \
    -o PidFile="${WINSUDO_WORKDIR}/winsudo.${PARENT_PID_PORT}.pid"
}

function internal::unprivileged-process() {
  if internal::is-elevated-process </dev/null &>/dev/null; then
    if [[ $# == 0 ]]; then
      return 0
    fi
    exec "$@"
  fi

  # need to set stdin, otherwise powershell will read stdin and it will be lost by the next process
  if ! internal::start-privileged-server </dev/null; then
    return 1
  fi

  if [[ $# == 0 ]]; then
    internal::ssh-with-cwd \$SHELL -l
  else
    # shellcheck disable=SC2046
    internal::ssh-with-login $(internal::escape-args "$@")
  fi
}

#===============================================================================
# main
#===============================================================================

function internal::main() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    print_help
    return 0
  fi

  if [[ "${1:-}" == "-v" ]]; then
    WINSUDO_VERBOSE=1
    shift
  fi

  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    print_help
    return 0
  fi

  # internal entrypoint for legacy elevated SSHD server
  if [[ "${1:-}" == "--privileged" ]]; then
    shift
    if ! internal::legacy-init; then
      return 1
    fi
    internal::privileged-process "$@"
    return
  fi

  # prefer native Windows sudo when available in inline mode
  if internal::validate-native-sudo; then
    internal::native-sudo "$@"
    return
  fi

  # fall back to legacy SSH-based elevation
  if ! internal::legacy-init; then
    return 1
  fi
  internal::unprivileged-process "$@"
}

internal::main "$@"
