#!/usr/bin/env bash
# Open Notepad++ from WSL with path translation.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: npp [OPTION]... [FILE-OR-ARG...]
Open Notepad++ from WSL, translating existing file paths to Windows paths.

Options:
  -h, --help                  show this help and exit

All remaining arguments are forwarded to Notepad++.
If stdin is piped, it is appended as the final argument.
If Notepad++ is unavailable, falls back to nvim, vim, or vi.
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

# make sure we go to the right path
PGM_PATH="Program Files"
if [[ -d "$(wslpath -ua "c:/")Program Files (x86)/Notepad++/" ]]; then
  PGM_PATH="Program Files (x86)"
fi

PROGRAM="$(wslpath -ua "c:/${PGM_PATH}/Notepad++/notepad++.exe")"
if [[ ! -e "${PROGRAM}" ]]; then
  # fallback to a vi program
  FALLBACK_EDITOR="$(which nvim vim vi 2>/dev/null || true)"
  FALLBACK_EDITOR="${FALLBACK_EDITOR%%$'\n'*}"
  if [[ -z "${FALLBACK_EDITOR}" ]]; then
    echo "Unable to find a fallback editor." >&2
    exit 1
  fi
  exec "${FALLBACK_EDITOR}" "$@"
fi

# if there are any baked in arguments they are defined here
args=()

for arg in "$@"; do
  # if argument is a file, then expand it to windows paths
  if [ -e "$arg" ]; then
    # echo "arg $arg is a file"
    args=("${args[@]}" "$(wslpath -w "$arg")")
  else
    # echo "arg $arg is not a file"
    args=("${args[@]}" "$arg")
  fi
done

# test if we are in a pipe and pass stdin as last argument if we are piping in
if [ ! -t 0 ]; then
  args=("${args[@]}" "$(cat -)")
fi

"${PROGRAM}" -multiInst -nosession "${args[@]}"
