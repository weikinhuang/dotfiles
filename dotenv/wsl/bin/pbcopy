#!/usr/bin/env bash
#title              : pbcopy
#description        : Copy stdin into windows clipboard
#author             : Wei Kin Huang
#date               : 2022-05-29
#version            : 1.0.0
#usage              : pbcopy [args...]
#requires           : clip.exe
#===============================================================================

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: pbcopy [OPTION]... [CLIP-ARG...]
Copy stdin to the Windows clipboard with clip.exe.

Options:
  -h, --help                  show this help and exit

All remaining arguments are forwarded to clip.exe.
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

exec clip.exe "$@"
