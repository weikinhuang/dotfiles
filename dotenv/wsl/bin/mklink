#!/usr/bin/env bash
# Create Windows links from WSL via cmd.exe /c mklink.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

OPT_HARDLINK=
OPT_JUNCTION=
OPT_END=

targets=()

for arg in "$@"; do
  case "$arg" in
    -s | --symbolic | /s | /S) ;;
    -H | --hard | /h | /H)
      OPT_HARDLINK=1
      ;;
    -j | --junction | /j | /J)
      OPT_JUNCTION=1
      ;;
    -h | -\? | --help | /\?)
      cat - <<-EOF
Usage: mklink [OPTION]... TARGET [LINK_NAME]
Create Windows links from WSL via cmd.exe /c mklink.

Options:
  -s, --symbolic, /s, /S      create symbolic links (default)
  -H, --hard, /h, /H          create hard links
  -j, --junction, /j, /J      create directory junctions
  -h, -?, --help, /?          show this help and exit
      --                      stop option parsing

If LINK_NAME is omitted and TARGET contains a slash, the basename of TARGET is
used as the link name.
EOF
      exit 0
      ;;
    --)
      OPT_END=1
      ;;
    -*)
      if [[ -n ${OPT_END} ]]; then
        targets=("${targets[@]}" "${arg}")
        continue
      fi
      echo >&2 "mklink: unknown option '${arg}' (use --help for usage)"
      exit 1
      ;;
    *)
      targets=("${targets[@]}" "${arg}")
      ;;
  esac
done

if [[ ${#targets[@]} -eq 0 ]]; then
  echo >&2 "mklink: missing TARGET argument (use --help for usage)"
  exit 1
fi

if [[ ${#targets[@]} -eq 1 ]]; then
  if [[ "${targets[0]}" != */* ]]; then
    echo >&2 "mklink: missing LINK_NAME (cannot infer from '${targets[0]}' without a slash; pass an explicit name)"
    exit 1
  else
    targets=("${targets[0]}" "$(basename "${targets[0]}")")
  fi
elif [[ ${#targets[@]} -ne 2 ]]; then
  echo >&2 "mklink: too many arguments (expected TARGET [LINK_NAME], got ${#targets[@]})"
  exit 1
fi

# options for mkink windows command
opts=()

# symlink directories need a additional flag
if [[ -z ${OPT_HARDLINK} ]] && [[ -z ${OPT_JUNCTION} ]] && [[ -d "${targets[0]}" ]]; then
  opts=("${opts[@]}" "/d")
fi
if [[ -n ${OPT_HARDLINK} ]]; then
  opts=("${opts[@]}" "/h")
fi
if [[ -n ${OPT_JUNCTION} ]]; then
  opts=("${opts[@]}" "/j")
fi

# test for relative vs absolute
if [[ "${targets[1]}" == /* ]]; then
  opts=("${opts[@]}" "$(wslpath -w "${targets[1]}")")
else
  # shellcheck disable=SC1003
  opts=("${opts[@]}" "$(tr '/' '\\' <<<"${targets[1]}")")
fi

# mklink can only be called on Windows drives
# shellcheck disable=SC1003
if [[ "$(wslpath -w "${targets[0]}" 2>/dev/null)" == '\\wsl$\'* ]]; then
  echo >&2 "mklink: TARGET '${targets[0]}' is on the WSL filesystem; mklink can only link within Windows drives"
  exit 1
fi
# shellcheck disable=SC1003
if [[ "$(wslpath -w "${targets[1]}" 2>/dev/null)" == '\\wsl$\'* ]]; then
  echo >&2 "mklink: LINK_NAME '${targets[1]}' is on the WSL filesystem; mklink can only link within Windows drives"
  exit 1
fi

# add a windows path formatted target
# shellcheck disable=SC1003
opts=("${opts[@]}" "$(wslpath -w "${targets[0]}" || tr '/' '\\' <<<"${targets[0]}")")

"$(wslpath -u c:)/Windows/System32/cmd.exe" /c mklink "${opts[@]}"
