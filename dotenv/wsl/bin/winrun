#!/usr/bin/env bash
#title              : winrun
#description        : Run a command in cmd.exe with WSL path translation
#author             : Wei Kin Huang
#date               : 2022-06-07
#version            : 2.0.0
#usage              : winrun <command> [args...]
#requires           : cmd.exe wslpath
#===============================================================================
set -euo pipefail
IFS=$'\n\t'

if [[ $# -eq 0 ]]; then
  echo "Usage: winrun <command> [args...]" >&2
  exit 1
fi

args=()
for arg in "$@"; do
  if [[ ! "$arg" =~ ^/[a-z]$ ]] && [[ -e "$arg" ]]; then
    args+=("$(wslpath -wa "$arg")")
  else
    args+=("$arg")
  fi
done

exec cmd.exe /c "${args[@]}"
