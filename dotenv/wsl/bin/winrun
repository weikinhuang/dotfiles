#!/usr/bin/env bash
# Run a command in cmd.exe with WSL path translation.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: winrun [OPTION]... COMMAND [ARG...]
Run a Windows command under cmd.exe, translating existing WSL file paths.

Options:
  -h, --help                  show this help and exit

All remaining arguments are forwarded to cmd.exe /c after path translation.
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

if [[ $# -eq 0 ]]; then
  print_help >&2
  exit 1
fi

args=()
for arg in "$@"; do
  if [[ ! "$arg" =~ ^/[a-z]$ ]] && [[ -e "$arg" ]]; then
    args+=("$(wslpath -wa "$arg")")
  else
    args+=("$arg")
  fi
done

exec cmd.exe /c "${args[@]}"
