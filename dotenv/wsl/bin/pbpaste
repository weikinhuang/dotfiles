#!/usr/bin/env bash
#title              : pbpaste
#description        : Get windows clipboard into stdout
#author             : Wei Kin Huang
#date               : 2022-05-29
#version            : 1.0.0
#usage              : pbpaste [args...]
#requires           : powershell.exe sed
#===============================================================================

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: pbpaste [OPTION]...
Write the Windows clipboard contents to stdout.

Options:
  -h, --help                  show this help and exit
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

powershell.exe -NoProfile -NonInteractive -Command Get-Clipboard </dev/null | sed 's/\r$//'
