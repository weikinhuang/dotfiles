#!/usr/bin/env bash
# Paste the Windows clipboard to stdout from WSL.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: pbpaste [OPTION]...
Write the Windows clipboard contents to stdout.

Options:
  -h, --help                  show this help and exit
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

# Get-Clipboard writes to stdout using [Console]::OutputEncoding, which
# defaults to the legacy OEM code page and garbles non-ASCII content (e.g. the
# dot or pi characters). Force no-BOM UTF-8 first so multibyte text survives;
# a BOM-emitting encoding would prepend a stray U+FEFF to the paste.
# shellcheck disable=SC2016 # $false is a PowerShell literal, not a shell var
powershell.exe -NoProfile -NonInteractive -Command \
  '[Console]::OutputEncoding = [Text.UTF8Encoding]::new($false); Get-Clipboard' </dev/null | sed 's/\r$//'
