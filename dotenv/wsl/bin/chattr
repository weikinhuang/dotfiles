#!/usr/bin/env bash
# Set Windows file attributes from WSL using attrib.exe.
# SPDX-License-Identifier: MIT

# the name of the program
PROGRAM=$(wslpath -u "c:/Windows/system32/attrib.exe")

# if there are any baked in arguments they are defined here
args=()
attr=()
opts=()
FILE=""

function print_help() {
  cat <<'EOF'
Usage: chattr [OPTION]... [FILE]
Set Windows file attributes from WSL using attrib.exe.

Options:
  +R, -R                      set or clear the read-only attribute
  +A, -A                      set or clear the archive attribute
  +S, -S                      set or clear the system attribute
  +H, -H                      set or clear the hidden attribute
  +I, -I                      set or clear the not-content-indexed attribute
  /S, /s                      process matching files in the current directory
                                and all subdirectories
  /D, /d                      process directories as well as files
  /L, /l                      work on the symbolic link itself instead of its
                                target
      --all                   equivalent to /S /D
  -h, -?, --help, /?          show this help and exit
EOF
}

for arg in "$@"; do
  case "$arg" in
    -h | -\? | --help | /\?)
      print_help
      exit 0
      ;;

    [+-][RASHIrashi])
      attr=("${attr[@]}" "$(tr '[:lower:]' '[:upper:]' <<<"$arg")")
      ;;

    /[SDLsdl])
      opts=("${opts[@]}" "$(tr '[:lower:]' '[:upper:]' <<<"$arg")")
      ;;

    --all)
      # special command to process recursively
      opts=("${opts[@]}" "/S" "/D")
      ;;

    *)
      # this is the file we're working on
      if [[ -e "$arg" ]]; then
        FILE="$(wslpath -wa "$arg")"
      else
        echo "Path ${arg} not found."
        exit 1
      fi
      ;;
  esac
done

# make all arguments unique
# shellcheck disable=2207
attr=($(printf "%s\n" "${attr[@]}" | awk 'x[$0]++ == 0'))
# shellcheck disable=2207
opts=($(printf "%s\n" "${opts[@]}" | awk 'x[$0]++ == 0'))

# merge all the arguments in the right order
args=("${attr[@]}" "$FILE" "${opts[@]}")

# no file specified, then just run the program
if [[ -z "$FILE" ]]; then
  "${PROGRAM}"
  exit 0
fi

# otherwise run it with arguments
"${PROGRAM}" "${args[@]}"
exit 0
