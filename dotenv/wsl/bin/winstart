#!/usr/bin/env bash
#title              : winstart
#description        : Open arguments in native handler
#author             : Wei Kin Huang
#date               : 2026-03-11
#version            : 2.0.0
#usage              : winstart [args...]
#requires           : powershell.exe wslpath
#===============================================================================
set -euo pipefail
IFS=$'\n\t'

args=()
for arg in "$@"; do
  if [[ ! "$arg" =~ ^/[a-z]$ ]] && [[ -e "$arg" ]]; then
    args+=("$(wslpath -wa "$arg")")
  else
    args+=("$arg")
  fi
done

if [[ ${#args[@]} -eq 0 ]]; then
  echo "Usage: $(basename "$0") [args...]" >&2
  exit 1
fi

# Wrap each value in PS single-quotes (only ' needs escaping as '')
psargs=()
for arg in "${args[@]}"; do
  psargs+=("'${arg//\'/\'\'}'")
done

cmd="${psargs[0]}"
if [[ ${#psargs[@]} -gt 1 ]]; then
  printf -v arglist '%s, ' "${psargs[@]:1}"
  exec powershell.exe -NoProfile -NonInteractive -Command "Start-Process -FilePath ${cmd} -ArgumentList ${arglist%, }"
else
  exec powershell.exe -NoProfile -NonInteractive -Command "Start-Process -FilePath ${cmd}"
fi
