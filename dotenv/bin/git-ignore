#!/usr/bin/env bash
# Show or append patterns to the local or global gitignore.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: git-ignore [OPTION]... [PATTERN...]
Show the current ignore files, or append patterns to the local or global gitignore.

With no options and no PATTERN values, both the global and local ignore files
are shown.

Options:
  -l, --local                use .gitignore in the current directory
  -g, --global               use the configured global excludes file
  -h, --help                 display this help and exit
EOF
}

function show_contents() {
  local label="$1"
  local file="$2"

  if [[ -f "${file}" ]]; then
    echo "${label} gitignore: ${file}"
    cat "${file}"
  fi
}

function expand_home_path() {
  local path="$1"

  if [[ "${path}" == "~" ]]; then
    printf '%s\n' "${HOME}"
    return 0
  fi

  if [[ "${path}" == \~/* ]]; then
    printf '%s/%s\n' "${HOME}" "${path#~/}"
    return 0
  fi

  printf '%s\n' "${path}"
}

function get_global_ignore_file() {
  local global_ignore_file

  global_ignore_file="$(git config --global --path core.excludesfile 2>/dev/null || true)"
  if [[ -z "${global_ignore_file}" ]]; then
    global_ignore_file="$(git config --global core.excludesfile 2>/dev/null || true)"
  fi

  [[ -n "${global_ignore_file}" ]] || return 0
  expand_home_path "${global_ignore_file}"
}

function show_global() {
  local global_ignore_file

  global_ignore_file="$(get_global_ignore_file)"
  [[ -n "${global_ignore_file}" ]] || return 0
  show_contents Global "${global_ignore_file}"
}

function show_local() {
  show_contents Local .gitignore
}

function add_patterns() {
  local file="$1"
  local pattern

  mkdir -p "$(dirname "${file}")"
  echo "Adding pattern(s) to: ${file}"
  for pattern in "${@:2}"; do
    [[ -n "${pattern}" ]] || continue
    echo "... adding '${pattern}'"
    if [[ -f "${file}" ]] && grep -Fqx -- "${pattern}" "${file}"; then
      continue
    fi
    printf '%s\n' "${pattern}" >>"${file}"
  done
}

function add_global() {
  local global_ignore_file

  global_ignore_file="$(get_global_ignore_file)"
  if [[ -z "${global_ignore_file}" ]]; then
    echo "Global gitignore file is not configured." >&2
    return 1
  fi

  add_patterns "${global_ignore_file}" "$@"
}

function add_local() {
  add_patterns .gitignore "$@"
}

function main() {
  local scope=
  local -a patterns=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h | --help)
        print_help
        exit 0
        ;;
      -l | --local)
        if [[ -n "${scope}" && "${scope}" != "local" ]]; then
          echo "git-ignore: choose either --local or --global" >&2
          exit 1
        fi
        scope="local"
        ;;
      -g | --global)
        if [[ -n "${scope}" && "${scope}" != "global" ]]; then
          echo "git-ignore: choose either --local or --global" >&2
          exit 1
        fi
        scope="global"
        ;;
      --)
        shift
        while [[ $# -gt 0 ]]; do
          patterns+=("$1")
          shift
        done
        break
        ;;
      -*)
        echo "git-ignore: unknown argument: $1" >&2
        print_help >&2
        exit 1
        ;;
      *)
        patterns+=("$1")
        ;;
    esac
    shift
  done

  if [[ -z "${scope}" && ${#patterns[@]} -eq 0 ]]; then
    show_global
    echo "---------------------------------"
    show_local
    exit 0
  fi

  if [[ -z "${scope}" ]]; then
    scope="local"
  fi

  case "${scope}" in
    local)
      if [[ ${#patterns[@]} -gt 0 ]]; then
        add_local "${patterns[@]}"
        echo
      fi
      show_local
      ;;
    global)
      if [[ ${#patterns[@]} -gt 0 ]]; then
        add_global "${patterns[@]}"
        echo
      fi
      show_global
      ;;
  esac
}

main "$@"
