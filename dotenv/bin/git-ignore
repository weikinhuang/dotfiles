#!/usr/bin/env bash
# Show or append patterns to the local or global gitignore.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: git-ignore [OPTION]... [PATTERN...]
Show the current ignore files, or append patterns to the local or global gitignore.

With no options and no PATTERN values, both the global and local ignore files
are shown.

Options:
  -l, --local                use .gitignore in the current directory
  -g, --global               use the configured global excludes file
  -h, --help                 display this help and exit
EOF
}

function show_contents {
  if [[ -f "$2" ]]; then
    echo "$1 gitignore: $2"
    cat "$2"
  fi
}

function get_global_ignore_file {
  git config --global core.excludesfile 2>/dev/null || true
}

function show_global {
  local global_ignore_file

  global_ignore_file="$(get_global_ignore_file)"
  [[ -n "${global_ignore_file}" ]] || return 0
  show_contents Global "${global_ignore_file}"
}

function add_global {
  local global_ignore_file

  global_ignore_file="$(get_global_ignore_file)"
  if [[ -z "${global_ignore_file}" ]]; then
    echo "Global gitignore file is not configured." >&2
    return 1
  fi

  add_patterns "${global_ignore_file}" "$@"
}

function show_local {
  show_contents Local .gitignore
}

function add_local {
  add_patterns .gitignore "$@"
}

function add_patterns {
  local file="$1"
  local pattern

  echo "Adding pattern(s) to: ${file}"
  for pattern in "${@:2}"; do
    [[ -n "${pattern}" ]] || continue
    echo "... adding '$pattern'"
    if [[ -f "${file}" ]] && grep -Fqx -- "${pattern}" "${file}"; then
      continue
    fi
    printf '%s\n' "${pattern}" >>"${file}"
  done
}

if test $# -eq 0; then
  show_global
  echo "---------------------------------"
  show_local
else
  case "$1" in
    -h | --help)
      print_help
      ;;
    -l | --local)
      test $# -gt 1 && add_local "${@:2}" && echo
      show_local
      ;;
    -g | --global)
      test $# -gt 1 && add_global "${@:2}" && echo
      show_global
      ;;
    *)
      add_local "$@"
      ;;
  esac
fi
