#!/usr/bin/env bash
# Print commits since the latest tag or prepend a new changelog header.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: git-changelog [OPTION]... [CHANGELOG]
Print commits since the latest tag, or prepend a new changelog header to a file.

If CHANGELOG is omitted, the first matching change/history file in the
current directory is used, falling back to History.md.

Options:
  -l, --list                 print commits since the latest tag
  -h, --help                 display this help and exit
EOF
}

DATE="$(date +'%Y-%m-%d')"

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
  -l | --list)
    version=$(git describe --tags --abbrev=0 "$(git rev-list --tags --max-count=1)")
    if test -z "$version"; then
      git log --pretty="format:  * %s"
    else
      git log --pretty="format:  * %s" "${version}.."
    fi
    ;;
  *)
    CHANGELOG="${1:-}"
    if test "$CHANGELOG" = ""; then
      # shellcheck disable=SC2010
      CHANGELOG="$(ls | grep -E 'change|history' -i | head -n 1 || true)"
      if test "$CHANGELOG" = ""; then CHANGELOG='History.md'; fi
    fi
    tmp="$(mktemp "${TMPDIR:-/tmp}/git-changelog.XXXXXX")"
    trap 'rm -f "${tmp}"' EXIT
    printf '\nn.n.n / %s\n==================\n\n' "${DATE}" >|"${tmp}"
    git-changelog --list >>"${tmp}"
    printf '\n' >>"${tmp}"
    if [ -f "$CHANGELOG" ]; then cat "$CHANGELOG" >>"${tmp}"; fi
    mv "${tmp}" "$CHANGELOG"
    trap - EXIT
    test -n "${EDITOR:-}" && "$EDITOR" "$CHANGELOG"
    ;;
esac
