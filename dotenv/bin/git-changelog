#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

DATE="$(date +'%Y-%m-%d')"
HEAD="$(printf '\nn.n.n / %s\n==================\n\n' "${DATE}")"

case "$1" in
  -l | --list)
    version=$(git describe --tags --abbrev=0 "$(git rev-list --tags --max-count=1)")
    if test -z "$version"; then
      git log --pretty="format:  * %s"
    else
      git log --pretty="format:  * %s" "${version}.."
    fi
    ;;
  *)
    CHANGELOG=$1
    if test "$CHANGELOG" = ""; then
      # shellcheck disable=SC2010
      CHANGELOG="$(ls | grep -E 'change|history' -i | head -n 1 || true)"
      if test "$CHANGELOG" = ""; then CHANGELOG='History.md'; fi
    fi
    tmp="$(mktemp "${TMPDIR:-/tmp}/git-changelog.XXXXXX")"
    trap 'rm -f "${tmp}"' EXIT
    printf "%s" "$HEAD" >|"${tmp}"
    git-changelog --list >>"${tmp}"
    printf '\n' >>"${tmp}"
    if [ -f "$CHANGELOG" ]; then cat "$CHANGELOG" >>"${tmp}"; fi
    mv "${tmp}" "$CHANGELOG"
    trap - EXIT
    test -n "${EDITOR:-}" && "$EDITOR" "$CHANGELOG"
    ;;
esac
