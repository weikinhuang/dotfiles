#!/usr/bin/env bash
# Cherry-pick a commit from another git repository.
# SPDX-License-Identifier: MIT

function print_help() {
  cat <<'EOF'
Usage: git-cherry-pick-from [OPTION]... OTHER_PROJECT_DIR GIT_SHA [--] [PATH...]
Cherry-pick a commit from another git repository, optionally limited to selected paths.

Options:
  -h, --help                 display this help and exit

Operands:
  OTHER_PROJECT_DIR          path to the source git repository
  GIT_SHA                    commit to cherry-pick from the source repository
  PATH                       optional path filter applied to format-patch
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

# shellcheck disable=SC2034
USAGE='../other-git-project/ git-sha [--] [paths]'
# shellcheck disable=SC2034
SUBDIRECTORY_OK=Yes
# shellcheck source=/dev/null
. git-sh-setup
require_work_tree

set -euo pipefail
IFS=$'\n\t'

if [[ $# -lt 2 ]]; then
  print_help >&2
  exit 1
fi

OTHER_PROJECT_DIR="$1"
OTHER_PROJECT_SHA="$2"

# Resolve via rev-parse so worktrees (.git is a file) and bare repos both work.
if ! OTHER_PROJECT_GIT_DIR="$(git -C "${OTHER_PROJECT_DIR}" rev-parse --git-dir 2>/dev/null)"; then
  exit 1
fi
if [[ "${OTHER_PROJECT_GIT_DIR}" != /* ]]; then
  OTHER_PROJECT_GIT_DIR="${OTHER_PROJECT_DIR}/${OTHER_PROJECT_GIT_DIR}"
fi

if ! git --git-dir="${OTHER_PROJECT_GIT_DIR}" cat-file -e "${OTHER_PROJECT_SHA}"; then
  exit 1
fi

shift
shift

# clean up file separator
if [[ "${1:-}" == '--' ]]; then
  shift
fi

git --git-dir="${OTHER_PROJECT_GIT_DIR}" \
  format-patch -k -1 --stdout \
  "${OTHER_PROJECT_SHA}" \
  -- "$@" \
  | git am -3 -k
