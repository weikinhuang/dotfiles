#!/usr/bin/env bash
# Delete branches already merged into the default branch and prune them from origin.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: git-branch-prune [OPTION]...
Delete local branches already merged into the default branch and remove them from origin.

Options:
  -i, --interactive          confirm each branch before deleting it
  -h, --help                 display this help and exit
EOF
}

INTERACTIVE=
while [[ $# -gt 0 ]]; do
  case "$1" in
    -i | --interactive)
      INTERACTIVE="yes"
      ;;
    -h | --help)
      print_help
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      print_help >&2
      exit 1
      ;;
  esac
  shift
done

if ! git remote get-url --push origin >/dev/null 2>&1; then
  echo "You need to be in a git repo with a pushable \"origin\" remote!"
  exit 1
fi

MAIN_BRANCH="$(git-default-branch)"
if [ -z "${MAIN_BRANCH}" ]; then
  echo "Unable to determine default branch." >&2
  exit 1
fi

while IFS= read -r BRANCH; do
  if [ -z "${BRANCH}" ] || [ "${BRANCH}" = "${MAIN_BRANCH}" ]; then
    continue
  fi
  if [ -n "$INTERACTIVE" ]; then
    read -r -p "$(basename "$0"): remove branch '$BRANCH'? (y) " RESPONSE </dev/tty
    if [ "$RESPONSE" != 'y' ] && [ "$RESPONSE" != '' ]; then
      continue
    fi
  fi
  if ST="$(git branch -d "$BRANCH" 2>&1)"; then
    echo -n "Pruned \"$BRANCH\"; removing from origin..."
    if RST="$(git push origin ":$BRANCH" 2>&1)"; then
      echo " Removed."
    else
      echo
      echo "Branch \"$BRANCH\" not removed from origin: $RST"
    fi
  else
    ST="$(sed -n '1s/^error: //p' <<<"$ST")"
    echo "Branch \"$BRANCH\" not removed: $ST"
  fi
done < <(git branch --merged "${MAIN_BRANCH}" --format='%(refname:short)')
