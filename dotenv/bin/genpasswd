#!/usr/bin/env bash

function print_help() {
  cat <<'HELPDOC'
usage genpasswd [-?|--help] [-c:--chars:--charlist] [-a:--alpha] [-l:--length]
Generate a random password

-l, --length              the length of the password to generate
-c, --chars, --charlist   the character set that can be chosen from defaults to [a-zA-Z0-9-_!@#$%^&*()_+{}[]|:<>?=]
-a, --alpha               only use alpha numeric characters [a-zA-Z0-9] cannot be used with --charlist
-?, --help                display this message
HELPDOC
}

LENGTH=12
CHARS=
ALPHA=

while [[ $# -gt 0 ]]; do
  case "$1" in
    -\? | --help)
      print_help
      exit 0
      ;;
    -a | --alpha)
      ALPHA=1
      ;;
    -l | --length | --len)
      if [[ $# -lt 2 ]]; then
        echo "genpasswd: missing value for $1" >&2
        exit 1
      fi
      LENGTH="$2"
      shift
      ;;
    -l?*)
      LENGTH="${1#-l}"
      ;;
    --length=* | --len=*)
      LENGTH="${1#*=}"
      ;;
    -c | --chars | --charlist)
      if [[ $# -lt 2 ]]; then
        echo "genpasswd: missing value for $1" >&2
        exit 1
      fi
      CHARS="$2"
      shift
      ;;
    -c?*)
      CHARS="${1#-c}"
      ;;
    --chars=* | --charlist=*)
      CHARS="${1#*=}"
      ;;
    *)
      echo "genpasswd: unknown argument: $1" >&2
      exit 1
      ;;
  esac
  shift
done

if [[ -z "${CHARS}" ]]; then
  if [[ -n "${ALPHA}" ]]; then
    CHARS='a-zA-Z0-9'
  else
    CHARS='a-zA-Z0-9-_!@#$%^&*()_+{}[]|:<>?='
  fi
fi

openssl rand -base64 $((LENGTH * 2)) | tr -dc "$CHARS" | fold -w "$LENGTH" | head -n 1
