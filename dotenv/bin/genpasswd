#!/usr/bin/env bash
# Generate a random password.
# SPDX-License-Identifier: MIT

function print_help() {
  cat <<'HELPDOC'
Usage: genpasswd [OPTION]...
Generate a random password

Mandatory arguments to long options are also mandatory for the
corresponding short options.

Options:
  -a, --alpha                use only alphanumeric characters [a-zA-Z0-9]
  -c, --chars CHARS          use CHARS as the allowed character set
      --charlist CHARS         alias for --chars
      --chars=CHARS            set the character set inline
      --charlist=CHARS         set the character set inline
  -l, --length LENGTH        generate a password of LENGTH characters
      --len LENGTH             alias for --length
      --length=LENGTH          set the length inline
      --len=LENGTH             set the length inline
  -h, -?, --help             display this help and exit

Short forms \`-cVALUE\` and \`-lVALUE\` are also accepted.
HELPDOC
}

LENGTH=12
CHARS=
ALPHA=

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h | -\? | --help)
      print_help
      exit 0
      ;;
    -a | --alpha)
      ALPHA=1
      ;;
    -l | --length | --len)
      if [[ $# -lt 2 ]]; then
        echo "genpasswd: missing value for $1" >&2
        exit 1
      fi
      LENGTH="$2"
      shift
      ;;
    -l?*)
      LENGTH="${1#-l}"
      ;;
    --length=* | --len=*)
      LENGTH="${1#*=}"
      ;;
    -c | --chars | --charlist)
      if [[ $# -lt 2 ]]; then
        echo "genpasswd: missing value for $1" >&2
        exit 1
      fi
      CHARS="$2"
      shift
      ;;
    -c?*)
      CHARS="${1#-c}"
      ;;
    --chars=* | --charlist=*)
      CHARS="${1#*=}"
      ;;
    *)
      echo "genpasswd: unknown argument: $1" >&2
      exit 1
      ;;
  esac
  shift
done

if [[ -z "${CHARS}" ]]; then
  if [[ -n "${ALPHA}" ]]; then
    CHARS='a-zA-Z0-9'
  else
    CHARS='a-zA-Z0-9-_!@#$%^&*()_+{}[]|:<>?='
  fi
fi

openssl rand -base64 $((LENGTH * 2)) | tr -dc "$CHARS" | fold -w "$LENGTH" | head -n 1
