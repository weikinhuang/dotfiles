#!/usr/bin/env bash
# Discard tracked changes while storing an undo commit in the reflog.
# SPDX-License-Identifier: MIT
#
# @see https://github.com/weikinhuang/git-undo-index/

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: git-undo-index [OPTION]... [PATH...]
Discard tracked changes while storing an undo commit in the reflog.

Options:
  -h, --help                 display this help and exit
EOF
}

UNDO_INDEX_TEMP_INDEX=
UNDO_INDEX_TARGET_PATHS=()
UNDO_INDEX_CHANGED_PATHS=()

function cleanup_temp_index() {
  if [[ -n "${UNDO_INDEX_TEMP_INDEX}" && -f "${UNDO_INDEX_TEMP_INDEX}" ]]; then
    rm -f "${UNDO_INDEX_TEMP_INDEX}"
  fi
}

function current_ref() {
  git symbolic-ref --quiet --short HEAD 2>/dev/null || git rev-parse --short HEAD
}

function current_branch() {
  git symbolic-ref --quiet --short HEAD 2>/dev/null || true
}

function diff_names() {
  if [[ "${1:-}" == "--cached" ]]; then
    shift
    if [[ ${#UNDO_INDEX_TARGET_PATHS[@]} -gt 0 ]]; then
      git diff --cached --name-only --diff-filter=ACDMRTUXB -- "${UNDO_INDEX_TARGET_PATHS[@]}"
    else
      git diff --cached --name-only --diff-filter=ACDMRTUXB
    fi
    return 0
  fi

  if [[ ${#UNDO_INDEX_TARGET_PATHS[@]} -gt 0 ]]; then
    git diff --name-only --diff-filter=ACDMRTUXB -- "${UNDO_INDEX_TARGET_PATHS[@]}"
  else
    git diff --name-only --diff-filter=ACDMRTUXB
  fi
}

function has_unmerged_paths() {
  local unmerged_paths

  if [[ ${#UNDO_INDEX_TARGET_PATHS[@]} -gt 0 ]]; then
    unmerged_paths="$(git diff --name-only --diff-filter=U -- "${UNDO_INDEX_TARGET_PATHS[@]}")"
  else
    unmerged_paths="$(git diff --name-only --diff-filter=U)"
  fi

  [[ -n "${unmerged_paths}" ]]
}

function collect_changed_paths() {
  local path

  UNDO_INDEX_CHANGED_PATHS=()
  while IFS= read -r path; do
    [[ -n "${path}" ]] || continue
    UNDO_INDEX_CHANGED_PATHS+=("${path}")
  done < <(
    {
      diff_names
      diff_names --cached
    } | LC_ALL=C sort -u
  )
}

function build_undo_commit() {
  local head_commit="$1"
  local tree
  local commit_message="$2"

  UNDO_INDEX_TEMP_INDEX="$(mktemp "${TMPDIR:-/tmp}/git-undo-index.XXXXXX")"
  GIT_INDEX_FILE="${UNDO_INDEX_TEMP_INDEX}" git read-tree "${head_commit}"
  GIT_INDEX_FILE="${UNDO_INDEX_TEMP_INDEX}" git add -A -- "${UNDO_INDEX_CHANGED_PATHS[@]}"
  tree="$(GIT_INDEX_FILE="${UNDO_INDEX_TEMP_INDEX}" git write-tree)"

  printf '%s\n' "${commit_message}" | git commit-tree "${tree}" -p "${head_commit}"
}

function restore_paths() {
  if [[ ${#UNDO_INDEX_TARGET_PATHS[@]} -gt 0 ]]; then
    git restore --source=HEAD --staged --worktree -- "${UNDO_INDEX_TARGET_PATHS[@]}"
  else
    git restore --source=HEAD --staged --worktree -- :/
  fi
}

function cleanup_restore_reflog_entry() {
  local branch_name="${1:-}"

  git reflog delete --rewrite 'HEAD@{0}'
  if [[ -n "${branch_name}" ]]; then
    git reflog delete --rewrite "${branch_name}@{0}"
  fi
}

function main() {
  local branch_name
  local head_commit
  local current_ref
  local commit_subject
  local commit_message
  local undo_commit

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h | --help)
        print_help
        exit 0
        ;;
      --)
        shift
        while [[ $# -gt 0 ]]; do
          UNDO_INDEX_TARGET_PATHS+=("$1")
          shift
        done
        break
        ;;
      -*)
        echo "git-undo-index: unknown argument: $1" >&2
        print_help >&2
        exit 1
        ;;
      *)
        UNDO_INDEX_TARGET_PATHS+=("$1")
        ;;
    esac
    shift
  done

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "git-undo-index: not in a git repository" >&2
    exit 1
  fi

  if has_unmerged_paths; then
    echo "git-undo-index: cannot discard unmerged paths" >&2
    exit 1
  fi

  collect_changed_paths
  if [[ ${#UNDO_INDEX_CHANGED_PATHS[@]} -eq 0 ]]; then
    echo "No tracked changes to discard."
    exit 0
  fi

  trap 'cleanup_temp_index' EXIT

  branch_name="$(current_branch)"
  head_commit="$(git rev-parse HEAD)"
  current_ref="$(current_ref)"
  commit_subject="$(git log --format=%s -n 1 "${head_commit}")"
  commit_message="Undoing changes for ${current_ref}: ${commit_subject} on $(date)"
  undo_commit="$(build_undo_commit "${head_commit}" "${commit_message}")"

  restore_paths

  git update-ref -m "${commit_message}" HEAD "${undo_commit}" "${head_commit}"
  git update-ref -m "git-undo-index: restore HEAD" HEAD "${head_commit}" "${undo_commit}"
  cleanup_restore_reflog_entry "${branch_name}"
}

main "$@"
