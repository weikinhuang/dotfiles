#!/usr/bin/env bash
# Forward clipboard access over an HTTP socket.
# Thin wrapper that delegates to lib/node/clipboard-server.ts.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
DOTFILES_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd -P)"
readonly DOTFILES_ROOT

exec "${DOTFILES_ROOT}/lib/node/clipboard-server.ts" "$@"
