#!/usr/bin/env bash
# Watch a directory and rerun a command after each change.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: fswatch [OPTION]... DIRECTORY COMMAND [ARG...]
Watch DIRECTORY with inotifywait and run COMMAND from that directory after each event.

Options:
  -h, --help                  show this help and exit

COMMAND and remaining ARG... are invoked after each modify, move, create, or
delete event.
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

if [[ $# -lt 2 ]]; then
  print_help >&2
  exit 1
fi

DIRECTORY="$(readlink -f "${1}")"
shift

if [[ ! -d "${DIRECTORY}" ]]; then
  echo "fswatch: '${DIRECTORY}' is not a directory" >&2
  exit 1
fi

# Tab-delimited so watched paths with spaces survive the read.
inotifywait -mrs --timefmt '%s' --format '%T	%e	%w	%f' \
  --event modify \
  --event move \
  --event create \
  --event delete \
  "${DIRECTORY}" \
  | while IFS=$'\t' read -r _ _ _ _; do
    cd "${DIRECTORY}" || {
      echo "fswatch: failed to chdir to ${DIRECTORY}" >&2
      exit 1
    }
    "$@"
  done
