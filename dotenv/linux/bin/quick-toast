#!/usr/bin/env bash
# Show a toast notification.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: quick-toast [OPTION]... [SUMMARY] [BODY]
Show a desktop notification via notify-send.

Options:
  -h, --help                  show this help and exit

If no arguments are provided, a default alert message is used.
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

if [[ $# -eq 0 ]]; then
  set -- "ALERT FROM TERMINAL"
fi

if ! command -v notify-send &>/dev/null; then
  printf '\a'
  exit 1
fi

# if tty, then try to show notif on the primary display
if [[ -z "${DISPLAY:-}" ]]; then
  export DISPLAY=:0
fi

notify-send "$@"
