#!/usr/bin/env bash
#title              : pbcopy
#description        : Cross-platform copy to clipboard
#author             : Wei Kin Huang
#date               : 2022-05-29
#version            : 1.0.0
#usage              : pbcopy [args...]
#requires           : xclip or xsel
#===============================================================================

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: pbcopy
Copy stdin to the X clipboard using xclip or xsel.

Options:
  -h, --help                  show this help and exit
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

# if tty, then try to pipe it to the X clipboard of the primary display
# otherwise: Error: Can't open display: (null)
if [[ -z "${DISPLAY:-}" ]]; then
  export DISPLAY=:0
fi

if command -v xclip &>/dev/null; then
  exec xclip -selection clipboard
elif command -v xsel &>/dev/null; then
  exec xsel -i --clipboard
fi

echo "pbcopy: requires xclip or xsel" >&2
exit 1
