#!/usr/bin/env bash
# Copy stdin to the system clipboard on Linux.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: pbcopy
Copy stdin to the X clipboard using xclip or xsel.

Options:
  -h, --help                  show this help and exit
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

# if tty, then try to pipe it to the X clipboard of the primary display
# otherwise: Error: Can't open display: (null)
if [[ -z "${DISPLAY:-}" ]]; then
  export DISPLAY=:0
fi

if command -v xclip &>/dev/null; then
  exec xclip -selection clipboard
elif command -v xsel &>/dev/null; then
  exec xsel -i --clipboard
fi

echo "pbcopy: requires xclip or xsel" >&2
exit 1
