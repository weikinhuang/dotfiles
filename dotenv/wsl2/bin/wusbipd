#!/usr/bin/env bash
# Run the Windows usbipd.exe CLI through winsudo from WSL.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: wusbipd [OPTION]... [USBIPD-ARG...]
Run the Windows usbipd.exe CLI through winsudo from WSL.

Options:
  -h, --help                  show this help and exit

All remaining arguments are forwarded to usbipd.exe.
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

# make sure we go to the right path
PGM_PATH="Program Files"
if [[ -d "$(wslpath -ua "c:/")Program Files (x86)/usbipd-win/" ]]; then
  PGM_PATH="Program Files (x86)"
fi

PROGRAM="$(wslpath -ua "c:/${PGM_PATH}/usbipd-win/usbipd.exe")"
if [[ ! -e "${PROGRAM}" ]]; then
  exit 1
fi

winsudo "${PROGRAM}" "$@"
