#!/usr/bin/env bash
# Show a toast notification.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: quick-toast [OPTION]... [TITLE] [BODY]
Show a macOS notification via osascript.

Options:
  -h, --help                  show this help and exit

If only BODY is provided, the default title is used.
If no arguments are provided, the default title and alert body are used.
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

if [[ $# -eq 0 ]]; then
  TITLE="Terminal Notification"
  BODY="ALERT FROM TERMINAL"
elif [[ $# -eq 1 ]]; then
  TITLE="Terminal Notification"
  BODY="${1}"
elif [[ $# -gt 1 ]]; then
  TITLE="${1}"
  BODY="${2}"
fi

osascript - "${TITLE}" "${BODY}" <<EOF
  on run argv -- argv is a list of strings
    display notification (item 2 of argv) with title (item 1 of argv)
  end run
EOF
