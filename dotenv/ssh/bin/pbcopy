#!/usr/bin/env bash
# Copy stdin to the remote clipboard-server clipboard.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: pbcopy [OPTION]...
Copy stdin to clipboard-server when available, otherwise fall back to the local pbcopy.

Options:
  -h, --help                  show this help and exit

When the local fallback is used, any remaining arguments are passed to pbcopy.
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

CLIPBOARD_SERVER_CHECK=
CURL_OPTS=(-sSL)
CURL_HOST="http://localhost"
if [[ -n "${CLIPBOARD_SERVER_PORT:-}" ]]; then
  CURL_HOST="http://localhost:${CLIPBOARD_SERVER_PORT}"
  CLIPBOARD_SERVER_CHECK=1
elif [[ -S "${CLIPBOARD_SERVER_SOCK:-/tmp/clipboard-server.sock}" ]]; then
  CURL_OPTS+=(--unix-socket "${CLIPBOARD_SERVER_SOCK:-/tmp/clipboard-server.sock}")
  CLIPBOARD_SERVER_CHECK=1
fi

if
  [[ -n "${CLIPBOARD_SERVER_CHECK}" ]] \
    && curl "${CURL_OPTS[@]}" "${CURL_HOST}/ping" &>/dev/null </dev/null
then

  exec curl "${CURL_OPTS[@]}" -X POST "${CURL_HOST}/clipboard" --data-binary @-

fi

# fallback to local clipboard
PATH="$(echo "${PATH}" | tr ':' '\n' | grep -v dotenv/ssh/bin | tr '\n' : | sed -e 's/:$//' -e 's/^://')"
exec pbcopy "$@"
