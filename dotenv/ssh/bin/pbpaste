#!/usr/bin/env bash
# Paste from the remote clipboard-server clipboard.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: pbpaste [OPTION]...
Read clipboard-server contents when available, otherwise fall back to the local pbpaste.

Options:
  -h, --help                  show this help and exit

When the local fallback is used, any remaining arguments are passed to pbpaste.
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

CLIPBOARD_SERVER_CHECK=
CURL_OPTS=(-sSL)
CURL_HOST="http://localhost"
if [[ -n "${CLIPBOARD_SERVER_PORT:-}" ]]; then
  CURL_HOST="http://localhost:${CLIPBOARD_SERVER_PORT}"
  CLIPBOARD_SERVER_CHECK=1
elif [[ -S "${CLIPBOARD_SERVER_SOCK:-/tmp/clipboard-server.sock}" ]]; then
  CURL_OPTS+=(--unix-socket "${CLIPBOARD_SERVER_SOCK:-/tmp/clipboard-server.sock}")
  CLIPBOARD_SERVER_CHECK=1
fi

if
  [[ -n "${CLIPBOARD_SERVER_CHECK}" ]] \
    && curl "${CURL_OPTS[@]}" "${CURL_HOST}/ping" &>/dev/null </dev/null
then

  exec curl "${CURL_OPTS[@]}" -X GET "${CURL_HOST}/clipboard"

fi

# fallback to local clipboard: find pbpaste in PATH, skipping this script's own directory
_self_dir="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
_remaining="${PATH}"
while [[ -n "${_remaining}" ]]; do
  _dir="${_remaining%%:*}"
  [[ "${_remaining}" == *:* ]] && _remaining="${_remaining#*:}" || _remaining=""
  [[ "${_dir}" == "${_self_dir}" ]] && continue
  if [[ -x "${_dir}/pbpaste" ]]; then
    exec "${_dir}/pbpaste" "$@"
  fi
done
echo "pbpaste: no fallback clipboard command found in PATH" >&2
exit 1
