#!/usr/bin/env bash
# Paste from the remote clipboard-server clipboard.
# SPDX-License-Identifier: MIT

set -euo pipefail
IFS=$'\n\t'

function print_help() {
  cat <<'EOF'
Usage: pbpaste [OPTION]...
Read clipboard-server contents when available, otherwise fall back to the local pbpaste.

Options:
  -h, --help                  show this help and exit

When the local fallback is used, any remaining arguments are passed to pbpaste.
EOF
}

case "${1:-}" in
  -h | --help)
    print_help
    exit 0
    ;;
esac

CLIPBOARD_SERVER_CHECK=
CURL_OPTS=(-sSL)
CURL_HOST="http://localhost"
if [[ -n "${CLIPBOARD_SERVER_PORT:-}" ]]; then
  CURL_HOST="http://localhost:${CLIPBOARD_SERVER_PORT}"
  CLIPBOARD_SERVER_CHECK=1
elif [[ -S "${CLIPBOARD_SERVER_SOCK:-/tmp/clipboard-server.sock}" ]]; then
  CURL_OPTS+=(--unix-socket "${CLIPBOARD_SERVER_SOCK:-/tmp/clipboard-server.sock}")
  CLIPBOARD_SERVER_CHECK=1
fi

if
  [[ -n "${CLIPBOARD_SERVER_CHECK}" ]] \
    && curl "${CURL_OPTS[@]}" "${CURL_HOST}/ping" &>/dev/null </dev/null
then

  exec curl "${CURL_OPTS[@]}" -X GET "${CURL_HOST}/clipboard"

fi

function exec_local_fallback() {
  local command_name="$1"
  shift

  local self_dir stripped_path=
  local dir candidate_dir
  local -a path_entries=()
  local -a fallback_entries=()

  self_dir="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
  IFS=: read -r -a path_entries <<<"${PATH}"

  for dir in "${path_entries[@]}"; do
    [[ "${dir}" == "${self_dir}" ]] && continue
    fallback_entries+=("${dir}")
    if [[ -z "${stripped_path}" ]]; then
      stripped_path="${dir}"
    else
      stripped_path="${stripped_path}:${dir}"
    fi
  done

  for dir in "${fallback_entries[@]}"; do
    candidate_dir="${dir:-.}"
    if [[ -x "${candidate_dir}/${command_name}" ]]; then
      PATH="${stripped_path}" exec "${candidate_dir}/${command_name}" "$@"
    fi
  done

  echo "${command_name}: no fallback clipboard command found in PATH" >&2
  exit 1
}

exec_local_fallback pbpaste "$@"
